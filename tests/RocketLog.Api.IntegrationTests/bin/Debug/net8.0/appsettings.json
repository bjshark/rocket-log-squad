{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*",
  "ConnectionStrings": {
    "MongoDb": "mongodb://localhost:27017"
  },
  "MongoDb": {
    "ConnectionString": "mongodb://localhost:27017",
    "DatabaseName": "rocket_log"
  },
  "Auth": {
    "Enabled": true,
    "DevUser": {
      "Subject": "dev-admin",
      "Email": "dev-admin@rocketlog.local",
      "DisplayName": "Rocket Log Dev Admin",
      "Roles": [ "admin", "user" ]
    },
    "Jwt": {
      "Issuer": "RocketLog.Api",
      "Audience": "RocketLog.Client",
      "SigningKey": "rocket-log-dev-signing-key-please-change-before-production"
    }
  }
}
